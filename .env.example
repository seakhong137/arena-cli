# ============================================
# The Arena — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ── Telegram ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_channel_or_group_id_here

# ── Gemini API ──────────────────────────────
# API key for Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
# Model to use for agent inference
GEMINI_MODEL=gemini-2.0-flash
# Timeout per agent call in seconds (optional, default: from config)
GEMINI_TIMEOUT=180

# ── TradingView MCP ───────────────────────
# Directory path to tradingview-mcp server
MCP_SERVER_DIR=/Users/khong/ai-cli/tradingview-mcp
# MCP server port (if running as standalone)
MCP_SERVER_PORT=3000

# ── Session Configuration ─────────────────
# NY Session hours (24h format, EST/EDT)
NY_SESSION_START=08:00
NY_SESSION_END=17:00
# Warm-up before session starts (minutes)
NY_SESSION_WARMUP=5
# Timezone
TIMEZONE=America/New_York

# ── Scan Configuration ────────────────────
# Scan interval in minutes
SCAN_INTERVAL_MINUTES=5
# Assets to scan (comma-separated)
ASSETS=FX:XAUUSD,FX:EURUSD,FX:GBPUSD,FX:USDJPY
# Primary timeframe
PRIMARY_TIMEFRAME=5
# Context timeframes (comma-separated)
CONTEXT_TIMEFRAMES=15,60,240

# ── Risk Manager ──────────────────────────
# Max signals per day (global)
MAX_DAILY_SIGNALS_GLOBAL=20
# Max signals per agent per day
MAX_DAILY_SIGNALS_PER_AGENT=5
# Minimum R:R ratio to approve
MIN_RISK_REWARD_RATIO=1.5
# Minimum confidence % to approve
MIN_CONFIDENCE_PCT=55
# ATR multiplier for volatility gate
VOLATILITY_ATR_MULTIPLIER=2.0
# Max correlated USD signals
MAX_CORRELATED_USD_SIGNALS=3

# ── Elimination ───────────────────────────
# Minimum signals per week for elimination eligibility
MIN_WEEKLY_SIGNALS=5
# Win rate threshold
ELIMINATION_WIN_RATE=40
# Profit factor threshold
ELIMINATION_PROFIT_FACTOR=1.0
# Max drawdown threshold %
ELIMINATION_MAX_DRAWDOWN=10

# ── Database ──────────────────────────────
DATABASE_PATH=./data/arena.db

# ── Logging ───────────────────────────────
LOG_LEVEL=info
LOG_FILE=./data/arena.log

# ── Dashboard ─────────────────────────────
DASHBOARD_PORT=3100
